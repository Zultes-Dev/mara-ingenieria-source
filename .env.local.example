# ─────────────────────────────────────────────────────────────
# .env.local.example
#
# Copiar este archivo como .env.local y llenar con valores reales.
# NUNCA commitear .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Contacto (requerido) ──────────────────────────────────────
# Número de WhatsApp en formato internacional SIN el +
# Ejemplo Colombia: 573001234567
NEXT_PUBLIC_WA_NUMBER=573203047122

# Teléfono de contacto visible en el sitio
NEXT_PUBLIC_PHONE=+57 320 304 7122

# Correo de contacto visible en el sitio
NEXT_PUBLIC_EMAIL=Maraingenieriasas@gmail.com

# Correo que RECIBE los formularios (puede ser diferente al público)
CONTACT_EMAIL=Maraingenieriasas@gmail.com

# ── Analytics (opcional) ──────────────────────────────────────
# Google Analytics 4 — dejar vacío para desactivar
NEXT_PUBLIC_GA_ID=

# ── Email / Formulario (elegir uno) ──────────────────────────
# Opción A: Resend (recomendado — gratis 3k emails/mes)
# https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Opción B: SMTP directo (Gmail, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=app-password-aqui

# ── Seguridad (generado automáticamente) ─────────────────────
# Para CSRF tokens si se implementa en el futuro
# openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Entorno ───────────────────────────────────────────────────
NODE_ENV=development
